<!-- TWEAKS PANEL -->
<div id="tweaks-panel">
  <button id="tweaks-close" aria-label="Close">×</button>
  <div class="tp-title">Tweaks</div>
  <div class="tp-sub">Цветовой акцент</div>
  <div class="tp-row" id="tp-swatches">
    <div class="tp-sw" data-accent="gold"     style="background: linear-gradient(135deg,#D9BC85,#8C6E3F);" title="Золото"></div>
    <div class="tp-sw" data-accent="bordo"    style="background: linear-gradient(135deg,#7A3A36,#3F1E1B);" title="Бордо"></div>
    <div class="tp-sw" data-accent="midnight" style="background: linear-gradient(135deg,#3C4A6B,#1A2238);" title="Ночь"></div>
    <div class="tp-sw" data-accent="mono"     style="background: linear-gradient(135deg,#2C2C2A,#0F0F0E);" title="Монохром"></div>
  </div>
  <div style="display:flex;justify-content:space-between;font-size:9px;letter-spacing:0.14em;text-transform:uppercase;color:var(--g500);margin-bottom:8px;padding:0 2px;">
    <span>Gold</span><span>Bordo</span><span>Night</span><span>Mono</span>
  </div>
  <label class="tp-toggle">
    <span style="font-variant:small-caps;letter-spacing:0.16em;">Бумажная текстура</span>
    <input type="checkbox" id="tp-grain" checked>
  </label>
</div>

<script>
(function(){
  const PALETTES = {
    gold:     { accent:'#B89968', deep:'#8C6E3F', soft:'#E8DAB8', line:'rgba(184,153,104,0.45)', faint:'rgba(184,153,104,0.10)' },
    bordo:    { accent:'#7A3A36', deep:'#5C2520', soft:'#D9B5B0', line:'rgba(122,58,54,0.40)',  faint:'rgba(122,58,54,0.08)' },
    midnight: { accent:'#3C4A6B', deep:'#26314A', soft:'#B8C2D9', line:'rgba(60,74,107,0.40)',  faint:'rgba(60,74,107,0.08)' },
    mono:     { accent:'#2C2C2A', deep:'#111110', soft:'#D3D1C7', line:'rgba(0,0,0,0.18)',      faint:'rgba(0,0,0,0.04)' }
  };
  const root = document.documentElement;
  function applyAccent(name){
    const p = PALETTES[name] || PALETTES.gold;
    root.style.setProperty('--accent', p.accent);
    root.style.setProperty('--accent-deep', p.deep);
    root.style.setProperty('--accent-soft', p.soft);
    root.style.setProperty('--accent-line', p.line);
    root.style.setProperty('--accent-faint', p.faint);
    document.querySelectorAll('.tp-sw').forEach(el => el.classList.toggle('active', el.dataset.accent === name));
    try { localStorage.setItem('oko_accent', name); } catch(e){}
  }
  function applyGrain(on){
    document.body.classList.toggle('no-grain', !on);
    try { localStorage.setItem('oko_grain', on ? '1':'0'); } catch(e){}
  }
  let saved = 'gold', grain = true;
  try { saved = localStorage.getItem('oko_accent') || 'gold'; grain = localStorage.getItem('oko_grain') !== '0'; } catch(e){}
  applyAccent(saved);
  applyGrain(grain);

  const panel = document.getElementById('tweaks-panel');
  const grainBox = document.getElementById('tp-grain');
  grainBox.checked = grain;
  document.getElementById('tp-swatches').addEventListener('click', e => {
    const sw = e.target.closest('.tp-sw'); if (!sw) return;
    applyAccent(sw.dataset.accent);
  });
  grainBox.addEventListener('change', () => applyGrain(grainBox.checked));
  document.getElementById('tweaks-close').addEventListener('click', () => {
    panel.classList.remove('open');
    try { window.parent.postMessage({type:'__edit_mode_dismissed'}, '*'); } catch(e){}
  });
  window.addEventListener('message', (e) => {
    const d = e.data || {};
    if (d.type === '__activate_edit_mode') panel.classList.add('open');
    if (d.type === '__deactivate_edit_mode') panel.classList.remove('open');
  });
  try { window.parent.postMessage({type:'__edit_mode_available'}, '*'); } catch(e){}
})();
</script>

