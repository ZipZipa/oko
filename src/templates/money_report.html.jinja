{%- set _ciii = locked_cfg['main_problem'] -%}
{%- if plan == 'demo' or _cur_level >= _plan_levels[_ciii.min_plan] %}
<!-- ═══ III: ГЛАВНАЯ ПРИЧИНА ПРОБЛЕМ ═══ -->
<div class="chapter-divider chap-wrap">
  <div class="chap-eyebrow">Часть третья</div>
  <div class="chap-title-big">Главная причина финансовых проблем</div>
  <div class="chap-num">III</div>
</div>

<div class="page">
{% call locked_card(_ciii.min_plan, _ciii.title, _ciii.pkg) %}
  <div class="card">
    <p class="q">{{ blocks.main_problem.intro_quote }}</p>
    <div style="text-align:center;padding:1.25rem 0 1rem;margin-bottom:1rem;border-bottom:0.5px solid var(--border);">
      <div class="ml" style="margin-bottom:0.4rem;">Имя паттерна</div>
      <div style="font-family:'Cormorant Garamond',serif;font-size:34px;font-weight:300;color:var(--black);">{{ blocks.main_problem.name }}</div>
    </div>
    <div class="bt">
      {% for item in blocks.main_problem.points %}
      <div class="ri"><div class="d"></div><span>{{ item }}</span></div>
      {% endfor %}
    </div>
  </div>

  <div class="g2">
    <div class="card" style="margin-bottom:0;">
      <div class="card-lbl">Корень</div>
      <div class="bt">{{ blocks.main_problem.root_cause }}</div>
    </div>
    {#- «Где проявляется» — базовый блок -#}
    {% call locked_block('base', 'Где проявляется', 'Базовый') %}
    <div class="card" style="margin-bottom:0;">
      <div class="card-lbl">Где проявляется</div>
