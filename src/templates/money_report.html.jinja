{%- set _civ = locked_cfg['money_code'] -%}
{%- if plan == 'demo' or _cur_level >= _plan_levels[_civ.min_plan] %}
<!-- ═══ IV: ДЕНЕЖНЫЙ КОД ═══ -->
<div class="chapter-divider chap-wrap">
  <div class="chap-eyebrow">Часть четвёртая</div>
  <div class="chap-title-big">Денежный код</div>
  <div class="chap-num">IV</div>
</div>

<div class="page">
{% call locked_card(_civ.min_plan, _civ.title, _civ.pkg) %}
  <div class="big-num-card">
    <div class="big-num-label">Твой денежный код</div>
