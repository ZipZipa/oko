      <div class="card-lbl">Естественная зона</div>
      <div class="bt">{{ blocks.ceiling.natural_zone }}</div>
    </div>
    {% endcall %}
  </div>

  {#- g2: оба блока — премиум. В demo показываем оба с замком. При extended — скрываем оба, нет grid. -#}
