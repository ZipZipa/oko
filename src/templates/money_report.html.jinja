      </div>
    </div>
    {% endcall %}
    {% call locked_block('full', 'Что удерживает внизу', 'Премиум') %}
    <div class="card" style="margin-bottom:0;">
      <div class="card-lbl">Что удерживает внизу</div>
      <div class="bt">
