  <div class="chap-eyebrow">Часть шестая</div>
  <div class="chap-title-big">Стратегия заработка</div>
  <div class="chap-num">VI</div>
</div>

<div class="page">
{% call locked_card(_cvi.min_plan, _cvi.title, _cvi.pkg) %}
  <div class="card">
    <p class="q">{{ blocks.earning_strategy.intro_quote }}</p>
    {#- «Природный путь» — расширенный блок -#}
