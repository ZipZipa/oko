body.no-grain::before { display: none !important; }

/* TWEAKS PANEL */
#tweaks-panel { display: none; position: fixed; right: 16px; bottom: 16px; z-index: 100; background: #FAFAF8; border: 0.5px solid var(--border-md); border-radius: 12px; padding: 14px 16px; box-shadow: 0 18px 50px rgba(0,0,0,0.12); width: 240px; font-family: 'Jost', sans-serif; }
#tweaks-panel.open { display: block; }
#tweaks-panel .tp-title { font-family: 'Cormorant Garamond', serif; font-size: 18px; color: var(--black); margin-bottom: 2px; }
#tweaks-panel .tp-sub { font-size: 9.5px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--g500); margin-bottom: 12px; }
#tweaks-panel .tp-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 6px; margin-bottom: 10px; }
#tweaks-panel .tp-sw { aspect-ratio: 1/1; border-radius: 50%; cursor: pointer; border: 1px solid rgba(0,0,0,0.1); position: relative; }
#tweaks-panel .tp-sw.active { box-shadow: 0 0 0 2px #FAFAF8, 0 0 0 3.5px var(--black); }
#tweaks-panel .tp-name { font-size: 10px; color: var(--g700); text-align: center; letter-spacing: 0.06em; }
#tweaks-panel .tp-toggle { display: flex; align-items: center; justify-content: space-between; font-size: 11px; color: var(--g700); padding: 8px 0; border-top: 0.5px solid var(--border); margin-top: 6px; }
#tweaks-panel .tp-toggle input { accent-color: var(--accent-deep); }
#tweaks-close { position: absolute; top: 8px; right: 10px; background: none; border: none; font-size: 18px; color: var(--g500); cursor: pointer; line-height: 1; }
</style>
</head>
<body>
{#- ══ ПЛАН ДОСТУПА ══════════════════════════════════════════════════════
    demo     — все главы видны, платные блоки скрыты замочком
    base     — I (обзор) + III, IV (проблема + код) + VII (прогноз)
    extended — + V, VI (потолок + стратегия) + VIII (сфера)
    full     — + II (ладонь), IX, X (якорь, смена работы)

    Хиромантия (II) — только в самом лучшем пакете (full/Премиум)

    Внутри глав — дополнительная блокировка отдельных блоков:
    base-блоки:     суть кода, как работает, где проявляется, yr.desc
    extended-блоки: природный путь, делай больше, перестань,
                    лучшие сферы, что притягивает, что отталкивает, ритм приходов
    full-блоки:     текущий уровень, естественная зона, что поднимет потолок,
                    что удерживает внизу, откуда взялся, как блокирует,
                    что растворяет якорь, текущая фаза, окно возможностей,
                    когда не стоит менять, сигналы к действию, что блокирует код
══════════════════════════════════════════════════════════════════════ -#}
{%- set _plan_levels = {'demo': 0, 'base': 1, 'extended': 2, 'full': 3} -%}
{%- set _cur_level   = _plan_levels.get(plan | default('full'), 3) -%}
{%- set locked_cfg = {
  'overview':         {'min_plan': 'demo', 'title': 'Денежный разбор',              'pkg': ''},
  'palmistry_money':  {'min_plan': 'full',     'title': 'Деньги по ладони',             'pkg': 'Премиум'},
  'main_problem':     {'min_plan': 'base',     'title': 'Главная причина проблем',  'pkg': 'Базовый'},
  'money_code':       {'min_plan': 'base',     'title': 'Денежный код',             'pkg': 'Базовый'},
  'ceiling':          {'min_plan': 'extended', 'title': 'Денежный потолок',         'pkg': 'Расширенный'},
  'earning_strategy': {'min_plan': 'extended', 'title': 'Стратегия заработка',      'pkg': 'Расширенный'},
  'forecast':         {'min_plan': 'base',     'title': 'Финансовый прогноз',       'pkg': 'Базовый'},
  'money_sphere':     {'min_plan': 'extended', 'title': 'Денежная сфера',           'pkg': 'Расширенный'},
  'anchor':           {'min_plan': 'full',     'title': 'Финансовый якорь',         'pkg': 'Премиум'},
  'career_change':    {'min_plan': 'full',     'title': 'Момент смены работы',      'pkg': 'Премиум'},
} -%}

{#- ══ МАКРОС: locked_card — блокирует целую страницу/главу ══
    В demo: всегда показывает содержимое (замки только на sub-блоках через locked_block)
    Куплено: показывает если уровень достаточен
    Не куплено (не demo): скрывает всё
-#}
{%- macro locked_card(min_plan, title, pkg) -%}
  {%- set min_level = _plan_levels.get(min_plan, 1) -%}
  {%- if _cur_level >= min_level or plan == 'demo' -%}
{{ caller() }}
  {%- endif -%}
{%- endmacro -%}

{#- ══ МАКРОС: locked_block — блокирует отдельный блок внутри карточки ══
    min_plan  — минимальный план для доступа
    title     — название блока для overlay
    pkg       — название пакета
    dark      — true если внутри dark-card (другой стиль overlay)
    В demo:      показывает с blur + замочком (фиктивно вытянут через min-height в CSS)
    Куплен:      показывает контент как есть
    Не куплен (не demo): скрывает блок полностью (не рендерится)
-#}
{%- macro locked_block(min_plan, title, pkg, dark=false) -%}
  {%- set min_level = _plan_levels.get(min_plan, 1) -%}
  {%- if _cur_level >= min_level -%}
{{ caller() }}
  {%- elif plan == 'demo' -%}
<div class="locked-block{% if dark %} locked-block-dark{% endif %}" aria-label="Заблокированный блок">
  <div class="locked-block-content" aria-hidden="true">{{ caller() }}</div>
  <div class="locked-block-overlay">
    <div class="locked-icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="11" width="14" height="9" rx="2"></rect><path d="M8 11V7.5a4 4 0 0 1 8 0V11"></path><circle cx="12" cy="15.5" r="1.1" fill="currentColor" stroke="none" style="fill: var(--accent-soft);"></circle></svg>
    </div>
    <div class="locked-title">{{ title }}</div>
    <div class="locked-eyebrow">Доступно в пакете</div>
    <div class="locked-pkg-name">{{ pkg }}</div>
  </div>
</div>
  {%- endif -%}
{%- endmacro -%}

{#- ══ ВСПОМОГАТЕЛЬНЫЕ ПЕРЕМЕННЫЕ для условных g2-сеток ══
    Используем для избегания пустых grid-ячеек когда соседний блок скрыт.
-#}
{%- set _base_ok     = (_cur_level >= 1 or plan == 'demo') -%}
{%- set _ext_ok      = (_cur_level >= 2 or plan == 'demo') -%}
{%- set _full_ok     = (_cur_level >= 3 or plan == 'demo') -%}

<!-- COVER -->
<div class="cover">
  <div class="cover-meta">
    <span class="mark">Oko</span>
    <span class="cover-edition">Денежный портрет</span>
  </div>

  <div class="cover-body">
    {# ── ID strip: mini photo + birthdate ── #}
    <div class="cover-id">
      {% if data.user.photo_url %}
      <div class="cover-id-photo"><img src="{{ data.user.photo_url }}" alt=""></div>
      {% else %}
      <div class="cover-id-photo-ph"></div>
      {% endif %}
      <div class="cover-id-info">
        <div class="cover-id-name">{{ data.user.name }}</div>
        <div class="cover-id-date">{{ data.user.birthdate }} · Персональный отчёт</div>
      </div>
    </div>

    {# ── Title block ── #}
    <div class="cover-center">
      <div class="cover-eyebrow">Глубинный финансовый анализ</div>
      <div class="cover-title">Деньги<br>и&nbsp;ты</div>
      <div class="cover-sub">Архетип · Код · Потолок · Стратегия · Прогноз</div>
    </div>

    {# ── Main archetype — денежный код ── #}
    <div class="cover-arch">
      <div class="cover-arch-num">{{ data.money.code.number }}</div>
      <div class="cover-arch-lbl">Денежный код · {{ data.money.code.formula }}</div>
      <div class="cover-arch-name">{{ data.money.archetype.type }}</div>
      <div class="cover-arch-short">{{ data.money.archetype.earning_style }}</div>
    </div>

    {# ── Key points ── #}
    <div class="cover-pts">
      {% for item in blocks.main_problem.points[:3] %}
      <div class="cover-pt"><div class="cover-pt-dot"></div><span>{{ item }}</span></div>
      {% endfor %}
    </div>

    {# ── Forecast timeline ── #}
    <div class="cover-tl">
      <div class="cover-tl-title">Финансовый прогноз</div>
      <div class="cover-tl-track">
        {% for y in blocks.forecast.years %}
        <div class="cover-tl-pt">
          <div class="cover-tl-dot {% if loop.index == 1 %}active{% endif %}"></div>
          <div class="cover-tl-num">{{ y.year }}</div>
          <div class="cover-tl-age">{{ y.tone }}</div>
        </div>
        {% endfor %}
      </div>
    </div>
  </div>

  <div class="cover-toc">
    <div class="toc-items">
      <span>I · Полный разбор</span>
      <span>II · По ладони</span>
      <span>III · Главная причина</span>
      <span>IV · Денежный код</span>
      <span>V · Потолок</span>
      <span>VI · Стратегия</span>
      <span>VII · Прогноз</span>
      <span>VIII · Денежная сфера</span>
      <span>IX · Якорь</span>
      <span>X · Смена работы</span>
    </div>
    <div class="toc-foot">
      <span>Персональный отчёт</span>
      <span>{{ data.user.birthdate }}</span>
    </div>
  </div>
</div>
{%- set _ci = locked_cfg['overview'] -%}
{%- if plan == 'demo' or _cur_level >= _plan_levels[_ci.min_plan] %}
<!-- ═══ I: ОБЗОР ═══ -->
<div class="chapter-divider chap-wrap">
  <div class="chap-eyebrow">Часть первая</div>
  <div class="chap-title-big">Полный денежный разбор</div>
  <div class="chap-num">I</div>
</div>

<div class="page">
{% call locked_card(_ci.min_plan, _ci.title, _ci.pkg) %}
  <div class="card">
    <p class="q">{{ blocks.overview.verdict_quote }}</p>
    <div class="bt">{{ blocks.overview.summary }}</div>
  </div>

  <div class="g2">
    <div class="card" style="margin-bottom:0;">
      <div class="card-lbl">Потенциал благосостояния</div>
      <div style="font-family:'Cormorant Garamond',serif;font-size:24px;color:var(--black);margin-bottom:0.5rem;">{{ blocks.overview.wealth_potential | capitalize }}</div>
      <div class="bt">Архетип «{{ data.money.archetype.type }}» — {{ data.money.archetype.earning_style }}.</div>
    </div>
    <div class="card" style="margin-bottom:0;">
      <div class="card-lbl">Отношения с деньгами</div>
      <div class="bt">{{ blocks.overview.money_relationship }}</div>
    </div>
  </div>

  <div class="card">
    <div class="card-lbl">Естественные сильные стороны и блоки</div>
    <div class="g2">
      <div class="mc">
        <div class="ml">Сила</div>
        <div class="bt">{{ data.money.archetype.natural_strength | capitalize }}</div>
      </div>
      <div class="mc">
        <div class="ml">Блок</div>
        <div class="bt">{{ data.money.archetype.typical_block | capitalize }}</div>
      </div>
    </div>
  </div>
{% endcall %}
</div>
{%- endif %}


{%- set _cii = locked_cfg['palmistry_money'] -%}
{%- if plan == 'demo' or _cur_level >= _plan_levels[_cii.min_plan] %}
<!-- ═══ II: ХИРОМАНТИЯ ═══ -->
<div class="chapter-divider chap-wrap">
  <div class="chap-eyebrow">Часть вторая</div>
  <div class="chap-title-big">Деньги по ладони</div>
  <div class="chap-num">II</div>
</div>

<div class="page">
{% call locked_block('full', _cii.title, _cii.pkg) %}
  <div class="card">
    <p class="q">{{ blocks.palmistry_money.intro_quote }}</p>
    <div class="card-lbl">Тип руки</div>
    <div class="bt" style="margin-bottom:1rem;">{{ blocks.palmistry_money.hand_pattern }}</div>
