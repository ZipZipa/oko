        {% endfor %}
      </div>
    </div>
    {% endcall %}
  </div>
  {%- endif %}

  <div class="final-line">{{ blocks.ceiling.final_line }}</div>
{% endcall %}
</div>
{%- endif %}


{%- set _cvi = locked_cfg['earning_strategy'] -%}
{%- if plan == 'demo' or _cur_level >= _plan_levels[_cvi.min_plan] %}
